      "y": 910,
      "width": 150,
      "height": 60,
      "text": "Non-Main Group\n(Untrusted)\n• 자기 폴더만 rw\n• 제한된 IPC 권한",
      "fontSize": 11,
      "fontFamily": 1,
      "textAlign": "center"
    },
